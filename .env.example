# ─── Database (Supabase / PostgreSQL) ───────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres"

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET="your_strong_random_jwt_secret_here"

# ─── Payment (Razorpay) ───────────────────────────────────────────────────────
# Use rzp_test_ prefix for test mode, rzp_live_ for production
RAZORPAY_KEY="rzp_test_xxxxxxxxxxxx"
# NEVER commit the real secret — keep it only in Vercel Environment Variables
RAZORPAY_SECRET="your_razorpay_key_secret"

# ─── Logistics (iCarry) ───────────────────────────────────────────────────────
ICARRY_USERNAME="your_icarry_username"
ICARRY_KEY="your_icarry_api_key"
# Get the pickup address ID from iCarry dashboard → Addresses → Pickup Addresses
ICARRY_PICKUP_ADDRESS_ID="84128"

# ─── AI (Hugging Face) ────────────────────────────────────────────────────────
# Optional — only needed if using the AI chat feature
HF_API_KEY="hf_xxxxxxxxxxxx"
